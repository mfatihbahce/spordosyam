		{
			"key": "base_url",
			"value": "https://altinpaletyuzmeakademi.com/spordosyam/spordosyam-web/api"
		},
		{
			"key": "token",
			"value": ""
		},
		{
			"key": "conversation_id",
			"value": "1"
		},
		{
			"key": "media_id",
			"value": "1"
