	"item": [
		{
			"name": "Auth",
			"item": [
				{
					"name": "Login (Veli)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    var json = pm.response.json();",
									"    if (json.token) {",
									"        pm.collectionVariables.set('token', json.token);",
									"        console.log('Token kaydedildi');",
									"    }",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Accept",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"veli@example.com\",\n  \"password\": \"sifre123\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/login",
							"host": ["{{base_url}}"],
							"path": ["login"]
						},
						"description": "Veli hesabı ile giriş. Başarılı olursa token otomatik kaydedilir."
					}
				},
				{
					"name": "Login (Antrenör)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    var json = pm.response.json();",
									"    if (json.token) {",
									"        pm.collectionVariables.set('token', json.token);",
									"        console.log('Token kaydedildi');",
									"    }",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Accept",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"antrenor@example.com\",\n  \"password\": \"sifre123\"\n}"
